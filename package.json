{
  "name": "servease-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:admin": "npm run dev --workspace=@servease/admin",
    "dev:landing": "npm run dev --workspace=@servease/landing",
    "dev:provider": "npm run dev --workspace=@servease/provider",
    "build:all": "npm run build --workspaces",
    "install:all": "npm install"
  }
}
