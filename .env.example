# ============================================================
# ServEase Admin/Provider Web Frontend — Environment Variables
# Copy this file to .env and fill in your values.
#
# All variables must be prefixed with VITE_ to be exposed
# to the browser by Vite.
# ============================================================

# ------------------------------------------------------------
# API (Required)
# The base URL of the ServEase backend gateway.
# Falls back to an empty string if not set, which will cause
# all API calls to fail — always set this.
# ------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:5000
